<% layout("layout/boilerplate") %>

<div class="form-wrapper">
  <h3 class="mb-4 text-start fw-bold">Edit Listing</h3>

  <form method="POST" action="/listing/<%= foundlisting._id %>?_method=PUT" class="needs-validation row g-3" novalidate enctype="multipart/form-data">
    <div class="col-12">
      <label class="form-label fw-semibold">Title</label>
      <input type="text" name="title" value="<%= foundlisting.title %>" class="form-control" required>
      <div class="invalid-feedback">Please enter a valid title.</div>
    </div>

    <div class="col-12">
      <label class="form-label fw-semibold">Description</label>
      <textarea name="description" rows="4" class="form-control" required><%= foundlisting.description %></textarea>
      <div class="invalid-feedback">Please enter a description.</div>
    </div>

    <div class="col-12 my-3">
      <p class="mb-2 fw-semibold">Current Listing Image</p>
      <img src="<%= foundlisting.image.url %>" alt="Listing Image" class="img-thumbnail" style="height: 120px; width: 180px; object-fit: cover; border-radius: 8px;">
    </div>

    <div class="col-12">
      <label class="form-label fw-semibold">Upload New Image File</label>
      <input type="file" name="avatar" class="form-control">
    </div>

    <div class="col-md-4">
      <label class="form-label fw-semibold">Price</label>
      <input type="number" name="price" value="<%= foundlisting.price %>" class="form-control" required>
      <div class="invalid-feedback">Please enter a valid price.</div>
    </div>

    <div class="col-md-8">
      <label class="form-label fw-semibold">Country</label>
      <input type="text" name="country" value="<%= foundlisting.country %>" class="form-control" required>
      <div class="invalid-feedback">Please enter a country name.</div>
    </div>

    <div class="col-12">
      <label class="form-label fw-semibold">Location</label>
      <input type="text" name="location" value="<%= foundlisting.location %>" class="form-control" required>
      <div class="invalid-feedback">Please enter location details.</div>
    </div>

    <div class="col-12 mt-4">
      <button type="submit" class="btn btn-brand w-100 py-2">Update Listing</button>
    </div>
  </form>
</div>