<% layout("layout/boilerplate") %>

<div class="form-wrapper">
  <h3 class="mb-4 text-start fw-bold">Add New Listing</h3>

  <form method="POST" action="/listing" class="needs-validation row g-3" novalidate enctype="multipart/form-data">
    <div class="col-12"> 
      <label class="form-label fw-semibold">Title</label>
      <input type="text" name="title" placeholder="Enter title" required class="form-control">
      <div class="invalid-feedback">Please enter a catchy title.</div>
    </div>

    <div class="col-12">
      <label class="form-label fw-semibold">Description</label>
      <textarea name="description" placeholder="Enter description" rows="4" required class="form-control"></textarea>
      <div class="invalid-feedback">Please enter a description.</div>
    </div>

    <div class="col-12">
      <label class="form-label fw-semibold">Upload Image File</label>
      <input type="file" name="avatar" class="form-control">
    </div>
 
    <div class="col-md-4">
      <label class="form-label fw-semibold">Price</label>
      <input type="number" name="price" placeholder="1200" required class="form-control">
      <div class="invalid-feedback">Please enter a valid price.</div>
    </div>

    <div class="col-md-8">
      <label class="form-label fw-semibold">Country</label>
      <input type="text" name="country" placeholder="India" required class="form-control">
      <div class="invalid-feedback">Please enter a country.</div>
    </div>

    <div class="col-12">
      <label class="form-label fw-semibold">Location</label>
      <input type="text" name="location" placeholder="New Delhi, Delhi" required class="form-control">
      <div class="invalid-feedback">Please enter a location.</div>
    </div>

    <div class="col-12 mt-4">
      <button type="submit" class="btn btn-brand w-100 py-2">Create Listing</button>
    </div>
  </form>
</div>